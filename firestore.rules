rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    function adminAlreadyExists() {
      return exists(/databases/$(database)/documents/meta/adminStatus) &&
        get(/databases/$(database)/documents/meta/adminStatus).data.exists == true;
    }

    // Tiny public status doc — lets the sign-in screen check "does an admin
    // account already exist?" before anyone is signed in.
    match /meta/adminStatus {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profiles are readable by any signed-in program member — needed for the
    // leaderboard, admin views, and showing names on posts. Only the owner
    // can create/update their own profile (or an admin can update anyone's).
    // Only one admin account may ever be created. Admins can delete an
    // affiliate's profile (removes their app access).
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) &&
        (request.resource.data.role != 'admin' || !adminAlreadyExists());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Readable by anyone signed in; only admins can add/edit the idea library.
    match /ideas/{ideaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Posts are readable by any signed-in member (leaderboard, admin views);
    // only the owning affiliate (or an admin) can create/update/delete.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    // Points ledger — readable by any signed-in member (leaderboard totals);
    // written automatically by the app. Never editable; only admins can
    // delete (used when removing an affiliate's data).
    match /points/{pointId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Badges earned — same pattern as points.
    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
